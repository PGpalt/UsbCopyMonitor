<Window x:Class="UsbCopyMon.Tray.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="USB Transfer Attribution"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True">
    <Border Padding="16">
        <StackPanel MinWidth="420" Orientation="Vertical" Margin="0">
            <TextBlock Text="Who made this transfer?" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
            <TextBlock x:Name="Summary" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <TextBox x:Name="NameBox" Margin="0,0,0,12" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
                <Button x:Name="OkBtn" Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OkBtn_Click"/>
                <Button Content="Cancel" Width="80" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
