<Window x:Class="UsbCopyMon.Tray.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="External Transfer Detected" Height="260" Width="520" WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Margin="0,8,0,8">
            <TextBlock x:Name="SummaryText" TextWrapping="Wrap"/>
            <TextBlock Text="Who made this transfer?" Margin="0,10,0,2"/>
            <TextBox x:Name="WhoBox"/>
            <TextBlock Text="Reason (optional)" Margin="0,8,0,2"/>
            <TextBox x:Name="ReasonBox"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
